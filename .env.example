# ─── Serveur ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development           # "production" en prod

# ─── MongoDB ───────────────────────────────────────────────────
# Créez un cluster gratuit sur https://cloud.mongodb.com
# Exemple : mongodb+srv://user:password@cluster.mongodb.net/rale
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/rale

# ─── SMTP — Envoi d'emails ─────────────────────────────────────
# Gmail : activez "Mots de passe d'application" dans votre compte Google
# (Compte → Sécurité → Validation en 2 étapes → Mots de passe d'app)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rale.asso@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx  # mot de passe d'application (pas votre mdp Gmail)

# ─── Destinataire admin ────────────────────────────────────────
MAIL_TO=rale.asso@gmail.com

# ─── Origines autorisées (CORS) ────────────────────────────────
# En production, remplacez par votre domaine réel :
# ALLOWED_ORIGINS=https://www.association-rale.fr
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── HelloAsso — Paiement & Webhook ───────────────────────────
# Espace HelloAsso > Paramètres > API pour récupérer ces clés.
HELLOASSO_CLIENT_ID=votre_client_id_helloasso
HELLOASSO_CLIENT_SECRET=votre_client_secret_helloasso

# Slug de votre organisation HelloAsso (partie après /associations/ dans votre URL)
# Exemple : https://www.helloasso.com/associations/association-rale → "association-rale"
HELLOASSO_ORG_SLUG=association-rale

# URL publique du site (utilisée pour les redirections après paiement)
# En local : http://localhost:5173  |  En prod : https://www.association-rale.fr
APP_URL=http://localhost:5173

# URL de redirection HelloAsso — DOIT être en HTTPS (localhost refusé par HelloAsso)
# En développement : utilisez un tunnel ngrok  → https://xxxx.ngrok-free.app
# En production    : mettez votre domaine réel → https://www.association-rale.fr
HELLOASSO_REDIRECT_BASE=https://www.association-rale.fr

# Secret HMAC pour vérifier l'authenticité des webhooks HelloAsso (recommandé)
# Configurez-le dans votre espace HelloAsso > Paramètres > Webhooks
# URL du webhook : https://votre-domaine.fr/api/webhook/helloasso
HELLOASSO_SECRET=votre_secret_helloasso

# ─── Tableau de bord administrateur ───────────────────────────
# Clé d'accès au tableau de bord admin : /api/admin?key=VOTRE_CLE
# Générez une clé sécurisée : openssl rand -hex 32
ADMIN_KEY=votre_cle_admin_longue_et_aleatoire
